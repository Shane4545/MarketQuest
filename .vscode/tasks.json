{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Time Traveller: serve dashboard (DASHBOARD_001 worktree)",
      "type": "shell",
      "command": "python -m http.server 8000 --bind 127.0.0.1 --directory web",
      "options": {
        "cwd": "${workspaceFolder}/../worktrees/AI NATATION V1 -Stock Market__DASHBOARD_001",
        "env": {}
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "http-server",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Time Traveller: open Cursor Simple Browser",
      "type": "shell",
      "command": "echo ${input:ttOpenSimpleBrowser}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "echo": false,
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Time Traveller: open dashboard in default browser (Edge/Chrome)",
      "type": "shell",
      "command": "powershell -NoProfile -Command \"Start-Sleep -Seconds 1; Start-Process 'http://127.0.0.1:8000/index.html'\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "echo": false,
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Time Traveller: serve + open in Cursor Simple Browser",
      "dependsOn": [
        "Time Traveller: serve dashboard (DASHBOARD_001 worktree)",
        "Time Traveller: open Cursor Simple Browser"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Time Traveller: serve + open in default browser",
      "dependsOn": [
        "Time Traveller: serve dashboard (DASHBOARD_001 worktree)",
        "Time Traveller: open dashboard in default browser (Edge/Chrome)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "ttOpenSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:8000/index.html"]
    }
  ]
}
